---
out: .
filename: potter-{flavor}.Xresources
---
! {{flavor.name}} — X11 Xresources (xterm, urxvt). AUTO-GENERATED by Quills.
! Load with:  xrdb -merge ~/.config/potter/potter-{{flavor.id}}.Xresources
*background:  {{base.hex}}
*foreground:  {{text.hex}}
*cursorColor: {{peach.hex}}
{{#each ansi}}*color{{code}}: {{normal.hex}}
{{/each}}{{#each ansi}}*color{{bright.code}}: {{bright.hex}}
{{/each}}
