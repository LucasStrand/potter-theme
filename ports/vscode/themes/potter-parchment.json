{
  "name": "Potter Parchment",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#faf9f5",
    "editor.foreground": "#141413",
    "editorLineNumber.foreground": "#c3b7a0",
    "editorLineNumber.activeForeground": "#d77250",
    "editorCursor.foreground": "#d77250",
    "editor.selectionBackground": "#d6cab4",
    "editor.lineHighlightBackground": "#ece6da",
    "editor.findMatchBackground": "#bd832466",
    "editorWhitespace.foreground": "#e3dacc",
    "editorIndentGuide.background1": "#ece6da",
    "sideBar.background": "#f2eee4",
    "sideBar.foreground": "#6b6357",
    "activityBar.background": "#f2eee4",
    "activityBar.foreground": "#d77250",
    "statusBar.background": "#f2eee4",
    "statusBar.foreground": "#6b6357",
    "titleBar.activeBackground": "#f2eee4",
    "titleBar.activeForeground": "#141413",
    "tab.activeBackground": "#faf9f5",
    "tab.activeForeground": "#141413",
    "tab.inactiveBackground": "#f2eee4",
    "tab.inactiveForeground": "#897f6d",
    "tab.activeBorderTop": "#d77250",
    "panel.background": "#f2eee4",
    "terminal.background": "#faf9f5",
    "terminal.foreground": "#141413",
    "terminal.ansiBlack": "#e3dacc",
    "terminal.ansiRed": "#b02619",
    "terminal.ansiGreen": "#788c5d",
    "terminal.ansiYellow": "#bd8324",
    "terminal.ansiBlue": "#4a6da0",
    "terminal.ansiMagenta": "#9a6aa0",
    "terminal.ansiCyan": "#4f8a78",
    "terminal.ansiWhite": "#6b6357",
    "terminal.ansiBrightBlack": "#d6cab4",
    "terminal.ansiBrightRed": "#b5544a",
    "terminal.ansiBrightGreen": "#788c5d",
    "terminal.ansiBrightYellow": "#bd8324",
    "terminal.ansiBrightBlue": "#4a6da0",
    "terminal.ansiBrightMagenta": "#9a6aa0",
    "terminal.ansiBrightCyan": "#4f8a78",
    "terminal.ansiBrightWhite": "#897f6d",
    "button.background": "#d77250",
    "button.foreground": "#faf9f5",
    "focusBorder": "#d77250",
    "list.activeSelectionBackground": "#e3dacc",
    "list.activeSelectionForeground": "#141413",
    "list.hoverBackground": "#ece6da",
    "input.background": "#ece6da",
    "input.foreground": "#141413",
    "editorError.foreground": "#b02619",
    "editorWarning.foreground": "#bd8324",
    "editorInfo.foreground": "#5a93a3",
    "gitDecoration.modifiedResourceForeground": "#bd8324",
    "gitDecoration.addedResourceForeground": "#788c5d",
    "gitDecoration.deletedResourceForeground": "#b02619"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#b0a48c", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#788c5d" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#c06b7a" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#d77250" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#141413" } },
    { "scope": ["variable.language", "variable.parameter"], "settings": { "foreground": "#b5544a" } },
    { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#9a6aa0" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#5a93a3" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#4a6da0" } },
    { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"], "settings": { "foreground": "#bd8324" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#4f86a0" } },
    { "scope": ["constant.language", "support.constant"], "settings": { "foreground": "#d77250" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#9a6aa0" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#bd8324" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#d77250", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#5a93a3" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#b02619" } }
  ]
}
