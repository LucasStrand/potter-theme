{
  "name": "Potter Ink",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#14110c",
    "editor.foreground": "#ece6da",
    "editorLineNumber.foreground": "#524634",
    "editorLineNumber.activeForeground": "#e28c6c",
    "editorCursor.foreground": "#e28c6c",
    "editor.selectionBackground": "#3b3122",
    "editor.lineHighlightBackground": "#221c14",
    "editor.findMatchBackground": "#e2b45c66",
    "editorWhitespace.foreground": "#2e261b",
    "editorIndentGuide.background1": "#221c14",
    "sideBar.background": "#0f0c08",
    "sideBar.foreground": "#c3b79f",
    "activityBar.background": "#0f0c08",
    "activityBar.foreground": "#e28c6c",
    "statusBar.background": "#0f0c08",
    "statusBar.foreground": "#c3b79f",
    "titleBar.activeBackground": "#0f0c08",
    "titleBar.activeForeground": "#ece6da",
    "tab.activeBackground": "#14110c",
    "tab.activeForeground": "#ece6da",
    "tab.inactiveBackground": "#0f0c08",
    "tab.inactiveForeground": "#a39884",
    "tab.activeBorderTop": "#e28c6c",
    "panel.background": "#0f0c08",
    "terminal.background": "#14110c",
    "terminal.foreground": "#ece6da",
    "terminal.ansiBlack": "#2e261b",
    "terminal.ansiRed": "#d87d70",
    "terminal.ansiGreen": "#9eb27f",
    "terminal.ansiYellow": "#e2b45c",
    "terminal.ansiBlue": "#8ca8ca",
    "terminal.ansiMagenta": "#c4a5ca",
    "terminal.ansiCyan": "#86b5a6",
    "terminal.ansiWhite": "#c3b79f",
    "terminal.ansiBrightBlack": "#3b3122",
    "terminal.ansiBrightRed": "#d19181",
    "terminal.ansiBrightGreen": "#9eb27f",
    "terminal.ansiBrightYellow": "#e2b45c",
    "terminal.ansiBrightBlue": "#8ca8ca",
    "terminal.ansiBrightMagenta": "#c4a5ca",
    "terminal.ansiBrightCyan": "#86b5a6",
    "terminal.ansiBrightWhite": "#a39884",
    "button.background": "#e28c6c",
    "button.foreground": "#14110c",
    "focusBorder": "#e28c6c",
    "list.activeSelectionBackground": "#2e261b",
    "list.activeSelectionForeground": "#ece6da",
    "list.hoverBackground": "#221c14",
    "input.background": "#221c14",
    "input.foreground": "#ece6da",
    "editorError.foreground": "#d87d70",
    "editorWarning.foreground": "#e2b45c",
    "editorInfo.foreground": "#91bcc6",
    "gitDecoration.modifiedResourceForeground": "#e2b45c",
    "gitDecoration.addedResourceForeground": "#9eb27f",
    "gitDecoration.deletedResourceForeground": "#d87d70"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#6e6049", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#9eb27f" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#dcaab2" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#e28c6c" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#ece6da" } },
    { "scope": ["variable.language", "variable.parameter"], "settings": { "foreground": "#d19181" } },
    { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#c4a5ca" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#91bcc6" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#8ca8ca" } },
    { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"], "settings": { "foreground": "#e2b45c" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#81b0c2" } },
    { "scope": ["constant.language", "support.constant"], "settings": { "foreground": "#e28c6c" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#c4a5ca" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#e2b45c" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#e28c6c", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#91bcc6" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#d87d70" } }
  ]
}
