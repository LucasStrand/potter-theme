---
out: foot
filename: potter-{flavor}.ini
---
# {{flavor.name}} — foot. AUTO-GENERATED by Quills.
# include this from foot.ini:  [main] include=~/.config/foot/potter-{{flavor.id}}.ini
[colors]
foreground={{bare text}}
background={{bare base}}
selection-foreground={{bare base}}
selection-background={{bare overlay2}}
cursor={{bare base}} {{bare peach}}
urls={{bare sky}}

{{#each ansi}}regular{{code}}={{bare normal.hex}}
{{/each}}{{#each ansi}}bright{{code}}={{bare bright.hex}}
{{/each}}
