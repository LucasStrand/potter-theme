{
  "name": "@potternu/palette",
  "version": "0.1.0",
  "description": "Potter color palette — source of truth (3 flavors × 26 colors) with JSON + typed bindings.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./palette.json": "./palette.json"
  },
  "files": [
    "dist",
    "palette.json"
  ],
  "keywords": ["potter", "color", "palette", "theme", "design-tokens", "catppuccin"],
  "homepage": "https://potter.nu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucasStrand/potter-theme.git",
    "directory": "palette"
  },
  "bugs": "https://github.com/LucasStrand/potter-theme/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node src/build.ts",
    "prepublishOnly": "node src/build.ts"
  }
}
