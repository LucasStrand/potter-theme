---
single: true
out: dist
filename: _potter.scss
---
// Potter — SCSS maps for all three flavors.
// AUTO-GENERATED by Quills from palette.json. Do not edit by hand.
//
//   @use "potter" as potter;
//   .btn { background: map-get(potter.$parchment, "peach"); }
{{#each flavors}}
$potter-{{id}}: (
{{#each colorList}}  "{{name}}": {{hex}},
{{/each}});
{{/each}}
$potter-flavors: (
  "parchment": $potter-parchment,
  "quill": $potter-quill,
  "ink": $potter-ink,
);
