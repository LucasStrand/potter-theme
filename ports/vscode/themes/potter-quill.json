{
  "name": "Potter Quill",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1c1812",
    "editor.foreground": "#efe9df",
    "editorLineNumber.foreground": "#5b4e3a",
    "editorLineNumber.activeForeground": "#e08a6a",
    "editorCursor.foreground": "#e08a6a",
    "editor.selectionBackground": "#453829",
    "editor.lineHighlightBackground": "#2a2218",
    "editor.findMatchBackground": "#e0b25a66",
    "editorWhitespace.foreground": "#362c20",
    "editorIndentGuide.background1": "#2a2218",
    "sideBar.background": "#17140f",
    "sideBar.foreground": "#c8bca4",
    "activityBar.background": "#17140f",
    "activityBar.foreground": "#e08a6a",
    "statusBar.background": "#17140f",
    "statusBar.foreground": "#c8bca4",
    "titleBar.activeBackground": "#17140f",
    "titleBar.activeForeground": "#efe9df",
    "tab.activeBackground": "#1c1812",
    "tab.activeForeground": "#efe9df",
    "tab.inactiveBackground": "#17140f",
    "tab.inactiveForeground": "#a99e8d",
    "tab.activeBorderTop": "#e08a6a",
    "panel.background": "#17140f",
    "terminal.background": "#1c1812",
    "terminal.foreground": "#efe9df",
    "terminal.ansiBlack": "#362c20",
    "terminal.ansiRed": "#d77b6e",
    "terminal.ansiGreen": "#9cb07d",
    "terminal.ansiYellow": "#e0b25a",
    "terminal.ansiBlue": "#8aa6c8",
    "terminal.ansiMagenta": "#c2a3c8",
    "terminal.ansiCyan": "#84b3a4",
    "terminal.ansiWhite": "#c8bca4",
    "terminal.ansiBrightBlack": "#453829",
    "terminal.ansiBrightRed": "#cf8f7f",
    "terminal.ansiBrightGreen": "#9cb07d",
    "terminal.ansiBrightYellow": "#e0b25a",
    "terminal.ansiBrightBlue": "#8aa6c8",
    "terminal.ansiBrightMagenta": "#c2a3c8",
    "terminal.ansiBrightCyan": "#84b3a4",
    "terminal.ansiBrightWhite": "#a99e8d",
    "button.background": "#e08a6a",
    "button.foreground": "#1c1812",
    "focusBorder": "#e08a6a",
    "list.activeSelectionBackground": "#362c20",
    "list.activeSelectionForeground": "#efe9df",
    "list.hoverBackground": "#2a2218",
    "input.background": "#2a2218",
    "input.foreground": "#efe9df",
    "editorError.foreground": "#d77b6e",
    "editorWarning.foreground": "#e0b25a",
    "editorInfo.foreground": "#8fbac4",
    "gitDecoration.modifiedResourceForeground": "#e0b25a",
    "gitDecoration.addedResourceForeground": "#9cb07d",
    "gitDecoration.deletedResourceForeground": "#d77b6e"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#786850", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#9cb07d" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#dba8b0" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#e08a6a" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#efe9df" } },
    { "scope": ["variable.language", "variable.parameter"], "settings": { "foreground": "#cf8f7f" } },
    { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#c2a3c8" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#8fbac4" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#8aa6c8" } },
    { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"], "settings": { "foreground": "#e0b25a" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#7faec0" } },
    { "scope": ["constant.language", "support.constant"], "settings": { "foreground": "#e08a6a" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#c2a3c8" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#e0b25a" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#e08a6a", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#8fbac4" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#d77b6e" } }
  ]
}
